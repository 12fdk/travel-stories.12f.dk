---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  heading?: string;
}

const { items, heading = "Frequently asked questions" } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

{
  items.length > 0 && (
    <section class="not-prose my-12" aria-labelledby="post-faq">
      <h2 id="post-faq" class="mb-6 text-2xl font-bold sm:text-3xl">
        {heading}
      </h2>
      <div class="space-y-3">
        {items.map((item) => (
          <details class="rounded-xl border border-base-300 bg-base-100 p-4 open:bg-base-200">
            <summary class="cursor-pointer text-base font-semibold sm:text-lg">
              {item.question}
            </summary>
            <p class="faq-answer mt-3 text-base-content/80">{item.answer}</p>
          </details>
        ))}
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </section>
  )
}
