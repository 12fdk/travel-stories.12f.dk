---
import { getCollection, type CollectionEntry } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import TldrBox from "../../components/blog/TldrBox.astro";
import InlineCTA from "../../components/blog/InlineCTA.astro";
import FaqSection from "../../components/blog/FaqSection.astro";
import RelatedPosts from "../../components/blog/RelatedPosts.astro";
import AuthorBio from "../../components/blog/AuthorBio.astro";
import { readingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
}

const { post, allPosts } = Astro.props as Props;
const { Content } = await post.render();
const { minutes } = readingTime(post.body);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const canonicalPath = `/blog/${post.slug}/`;
const canonicalURL = new URL(canonicalPath, Astro.site);
const ogImage = post.data.ogImage ?? `/og/${post.slug}.png`;

const related = (
  post.data.relatedSlugs.length > 0
    ? allPosts.filter((p) => post.data.relatedSlugs.includes(p.slug))
    : allPosts.filter((p) => p.slug !== post.slug).slice(0, 3)
).slice(0, 3);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  image: new URL(ogImage, Astro.site).href,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
  author: {
    "@type": "Person",
    name: post.data.author,
    url: "https://www.12f.dk",
  },
  publisher: {
    "@type": "Organization",
    name: "12f.dk",
    url: "https://www.12f.dk",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalURL.href,
  },
  keywords: [post.data.keyword, ...post.data.tags].join(", "),
  inLanguage: "en",
  isPartOf: {
    "@type": "Blog",
    name: "Travel Stories Blog",
    url: new URL("/blog/", Astro.site).href,
  },
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["[data-speakable]", ".faq-answer"],
  },
};

const faqNode =
  post.data.faq.length > 0
    ? {
        "@type": "FAQPage",
        "@id": `${canonicalURL.href}#faq`,
        mainEntity: post.data.faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: { "@type": "Answer", text: item.answer },
        })),
      }
    : null;
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImage}
  canonicalPath={canonicalPath}
  articleSchema={articleSchema}
  extraGraphNodes={faqNode ? [faqNode] : []}
  publishedTime={post.data.publishDate.toISOString()}
  modifiedTime={(post.data.updatedDate ?? post.data.publishDate).toISOString()}
  author={post.data.author}
  tags={[post.data.keyword, ...post.data.tags]}
>
  <article class="max-w-3xl mx-auto px-4 py-10 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-base-content/60">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-1.5" aria-hidden="true">/</span>
      <a href="/blog/" class="hover:text-primary">Blog</a>
    </nav>

    <header class="mb-8">
      <h1 class="mb-4 text-3xl font-bold leading-tight md:text-5xl">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-2 text-sm text-base-content/60">
        <span>By {post.data.author}</span>
        <span aria-hidden="true">•</span>
        <time datetime={post.data.publishDate.toISOString()}>
          {formatDate(post.data.publishDate)}
        </time>
        {post.data.updatedDate && (
          <>
            <span aria-hidden="true">•</span>
            <span>Updated {formatDate(post.data.updatedDate)}</span>
          </>
        )}
        <span aria-hidden="true">•</span>
        <span>{minutes} min read</span>
      </div>
      <p class="mt-6 text-lg leading-relaxed text-base-content/85 md:text-xl" data-speakable>
        {post.data.lede}
      </p>
    </header>

    <TldrBox items={post.data.tldr} />

    <div class="prose prose-lg max-w-none prose-headings:font-bold prose-h2:mt-12 prose-h2:text-3xl prose-h3:text-xl prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl">
      <Content />
    </div>

    <InlineCTA
      heading="Ready to put this into practice?"
      body="Travel Stories is the free iPhone app that turns this kind of advice into one tappable trip — itinerary, packing list, budget, documents, and memories included. No account, no subscription."
      buttonText="Get Travel Stories — Free on the App Store"
      trackingId={`blog-cta-end-${post.slug}`}
    />

    <FaqSection items={post.data.faq} />

    <AuthorBio name={post.data.author} />

    <RelatedPosts posts={related} />
  </article>

  <script is:inline define:vars={{ slug: post.slug }}>
    // Track 60-second read for blog conversion KPI
    if (typeof window !== "undefined") {
      let fired = false;
      const fire = () => {
        if (fired) return;
        fired = true;
        if (window.umami && typeof window.umami.track === "function") {
          window.umami.track("blog-read-60s", { slug });
        }
      };
      const timer = window.setTimeout(fire, 60000);
      document.addEventListener(
        "visibilitychange",
        () => {
          if (document.visibilityState === "hidden") window.clearTimeout(timer);
        },
        { once: true }
      );
    }
  </script>
</BlogLayout>
