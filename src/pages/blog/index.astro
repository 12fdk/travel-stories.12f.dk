---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { readingTime } from "../../utils/readingTime";

const allPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const postsWithMeta = allPosts.map((post) => ({
  post,
  minutes: readingTime(post.body).minutes,
}));

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<BlogLayout
  title="Travel Blog — Trip Planning, Packing & Budget Guides | Travel Stories"
  description="Practical, no-fluff guides on planning trips, packing smart, budgeting, and keeping travel memories. Written by the developer of Travel Stories."
  canonicalPath="/blog/"
  hideAppBanner={true}
>
  <main id="main" class="max-w-screen-lg mx-auto px-4 py-12 md:py-20">
    <header class="mb-14 max-w-3xl">
      <p class="m-0 flex items-center gap-3 text-sm font-semibold uppercase tracking-wide text-base-content/50">
        <span class="inline-block h-0.5 w-8 bg-primary"></span>
        Travel Stories Blog
      </p>
      <h1 class="mb-4 mt-5 text-4xl font-extrabold leading-[1.05] md:text-5xl">
        Plan better trips. Keep better memories.
      </h1>
      <p class="text-lg leading-relaxed text-base-content/70">
        Practical guides on planning, packing, and budgeting your trips — and on
        holding onto them afterwards. Real checklists, real methods, no fluff.
      </p>
    </header>

    {
      postsWithMeta.length === 0 ? (
        <p class="text-base-content/60">No posts yet — coming soon.</p>
      ) : (
        <ul class="grid list-none gap-8 p-0 md:grid-cols-2">
          {postsWithMeta.map(({ post, minutes }, index) => (
            <li class="group m-0 overflow-hidden rounded-box border border-base-300 bg-base-100 p-0 transition-colors hover:border-base-content/30">
              <a href={`/blog/${post.slug}/`} class="flex h-full flex-col">
                {post.data.cover && (
                  <div class="overflow-hidden border-b border-base-300 bg-base-200">
                    <img
                      src={post.data.cover}
                      alt={post.data.coverAlt ?? ""}
                      width={640}
                      height={360}
                      loading={index < 2 ? "eager" : "lazy"}
                      decoding="async"
                      class="aspect-[16/9] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                    />
                  </div>
                )}
                <div class="flex flex-1 flex-col p-6 sm:p-7">
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-base-content/40">
                    <time datetime={post.data.publishDate.toISOString()}>
                      {formatDate(post.data.publishDate)}
                    </time>
                    <span aria-hidden="true">·</span>
                    <span>{minutes} min</span>
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <>
                        <span aria-hidden="true">·</span>
                        <span>{tag}</span>
                      </>
                    ))}
                  </div>
                  <h2 class="mb-0 mt-3 text-xl font-bold leading-snug text-base-content transition-colors group-hover:text-primary sm:text-2xl">
                    {post.data.title}
                  </h2>
                  <p class="mt-3 text-base leading-relaxed text-base-content/70">
                    {post.data.description}
                  </p>
                  <span class="mt-5 inline-block self-start border-b-2 border-primary pb-1 text-sm font-semibold text-base-content">
                    Read more
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BlogLayout>
