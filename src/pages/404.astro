---
import NotFound from "@modules/notFound";
import Layout from "Layout.astro";
import defaultTemplateConfig from "utils/config";

// GitHub Pages serves dist/404.html for any unmatched path. Branded so a bad
// link keeps the site chrome and routes people back in. Noindexed: error pages
// have no business in the index.
const config = {
  ...defaultTemplateConfig,
  seo: {
    title: "Page not found — Travel Stories",
    description: "That page was moved, renamed, or never existed.",
  },
};
---

<Layout {...config} noindex>
  <NotFound client:load config={config} />
</Layout>
